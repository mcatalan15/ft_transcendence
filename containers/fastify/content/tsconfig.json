{
	"compilerOptions": {
	  "outDir": "./dist",
	  "target": "ES2020",
	  "module": "ESNext",
	  "moduleResolution": "node",
	  "esModuleInterop": true,
	  "strict": true,
	  "sourceMap": true,
	  "resolveJsonModule": true,
	  "jsx": "preserve",
	  "lib": ["DOM", "DOM.Iterable", "ESNext"],
	  "allowJs": true,
	  "forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js"],
	"exclude": ["node_modules"]
  }